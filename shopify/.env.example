# Wild Wild Shopify — development only. Never commit .env
# Copy to .env and fill from Shopify Admin → Settings → Apps → Develop apps

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2025-01

# Custom app — Admin API (server/scripts only — never expose in shop.html)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Custom app — Storefront API (public cart/checkout token; limited scopes only)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: used by verify-store-settings.js
SHOPIFY_STOREFRONT_PASSWORD=your-dev-password
